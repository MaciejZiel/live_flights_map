FLASK_DEBUG=true
HOST=127.0.0.1
PORT=5000

# OpenSky credentials can stay empty for anonymous access, but rate limits are stricter.
FLIGHT_DATA_PROVIDERS=opensky,adsb_lol
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
OPENSKY_TIMEOUT=10
OPENSKY_RETRY_COUNT=1
ADSB_LOL_BASE_URL=https://api.adsb.lol
ADSB_LOL_TIMEOUT=10
ADSB_LOL_RETRY_COUNT=1
ADSB_LOL_RADIUS_LIMIT_NM=250
OPENSKY_CACHE_TTL=25
OPENSKY_COOLDOWN_SECONDS=75
FLIGHT_STREAM_INTERVAL_SECONDS=30

# Default map coverage: Poland and nearby airspace.
MAP_DEFAULT_LAMIN=49.0
MAP_DEFAULT_LAMAX=55.1
MAP_DEFAULT_LOMIN=14.0
MAP_DEFAULT_LOMAX=24.5

# Use '*' for local development or a specific frontend origin in production.
CORS_ALLOWED_ORIGIN=*
