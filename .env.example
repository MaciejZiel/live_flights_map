FLASK_DEBUG=true
PORT=5000

# OpenSky credentials can stay empty for anonymous access, but rate limits are stricter.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
OPENSKY_TIMEOUT=10

# Default map coverage: Poland and nearby airspace.
MAP_DEFAULT_LAMIN=49.0
MAP_DEFAULT_LAMAX=55.1
MAP_DEFAULT_LOMIN=14.0
MAP_DEFAULT_LOMAX=24.5

# Use '*' for local development or a specific frontend origin in production.
CORS_ALLOWED_ORIGIN=*
