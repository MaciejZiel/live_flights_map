VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5173

# Leave empty to use Vite proxy. Set an absolute URL to call the backend directly.
VITE_API_BASE_URL=

# Used only when VITE_API_BASE_URL is empty and requests go through the Vite dev proxy.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:5000

VITE_REFRESH_INTERVAL_MS=30000
VITE_BBOX_DEBOUNCE_MS=900
VITE_USE_SSE=false
